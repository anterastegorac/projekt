Zahtijev 1 Implementiran CRUD. Datoteka funkcije.c, 17 linija u kodu

void CRUD_create(const Statistika* s) {
	if (s == NULL)return;
	FILE* fp = fopen(FILENAME, "ab");
	if (fp == NULL) {
		perror("Pogreska pri otvaranju datoteke");
		return;
	}
	fwrite(s, sizeof(Statistika), 1, fp);
	fclose(fp);
}

